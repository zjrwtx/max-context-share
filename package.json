{
  "name": "max-context-share",
  "version": "0.1.0",
  "description": "CLI tool to export and import OpenClaw skills, workspace context files, and config fragments",
  "keywords": ["openclaw", "cli", "context", "skills", "workspace"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "max-ctx": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --noEmit --watch"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "tar": "^7.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/tar": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
